$
$ SNL-SWAN INPUT — generated by 03_build_swan_inputs.py
$ problem_id : {{ problem_id }}
$ layout_id  : {{ layout_id }}
$ sea_state  : {{ sea_state_id }}  Hs={{ Hs }} m  Tp={{ Tp }} s  Dir={{ Dir }} deg
$
PROJECT 'esposende_surrogate' '{{ run_id | default("") }}'

MODE NONSTATIONARY TWODIMENSIONAL

COORDINATES SPHERICAL

$ ── Grid ────────────────────────────────────────────────────────────────────
CGRID UNSTRUCTURED EXCEPTION 0.0

READGRID UNSTRUCTURED {{ grid_file }}

$ ── Bathymetry ───────────────────────────────────────────────────────────────
INPGRID BOTTOM UNSTRUCTURED EXCEPTION -999.0
READINP BOTTOM 1.0 '{{ bottom_file }}' 3 FREE

$ ── Boundary / initial conditions ───────────────────────────────────────────
BOUND SHAPESPEC JONSWAP {{ Hs }} {{ Tp }} DSPR DEGREES 30.0
BOUNDSPEC SEGMENT XY ... VARIABLE FILE

$ ── WEC obstacles ────────────────────────────────────────────────────────────
{{ wec_block }}

$ ── Physics ──────────────────────────────────────────────────────────────────
GEN3 WESTIN
WCAP KOMEN
QUAD
BREA
FRIC JONSWAP 0.067

$ ── Numerics ─────────────────────────────────────────────────────────────────
PROP BSBT
NUM ACCUR 0.02 0.02 0.02 98 NONSTAT 20

$ ── Output ───────────────────────────────────────────────────────────────────
BLOCK 'COMPGRID' NOHEAD 'Hs.mat'  LAY 3 HSIGN  1.0
BLOCK 'COMPGRID' NOHEAD 'Tm01.mat' LAY 3 RTM01 1.0
BLOCK 'COMPGRID' NOHEAD 'Dir.mat'  LAY 3 DIR   1.0

COMPUTE STAT
STOP
